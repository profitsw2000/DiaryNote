<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/restore_backup_fragment_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/standard_vertical_margin_between_views"
    tools:context=".presentation.view.account.BackupRestoreFragment">

    <TextView
        android:id="@+id/warning_content_text_view"
        style="@style/action_explanations_standard_text_style"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:text="Сохраните данные всех локальных пользователей, чтобы восстановить их при переустановке приложения или смене устройства на Android.\n\nДля создания резервной копии сохраните файл с данными на диске.\n\nДля восстановления данных выберите файл с ранее сохранённой резервной копией.\n\nПри восстановлении все текущие данные (заметки, информация о пользователях) будут заменены данными из файла с резервной копией."/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/buttons_constraint_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/warning_content_text_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingTop="@dimen/standard_vertical_margin_between_views">

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:id="@+id/restore_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/create_backup_button"
            app:layout_constraintTop_toTopOf="parent"
            android:text="Восстановить"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_backup_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@id/restore_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:text="Создать копию"/>

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>